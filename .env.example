# InterLink Relayer Configuration
# Copy this file to .env and fill in your values.

# EVM source chain ID (1=Ethereum, 42161=Arbitrum, 10=Optimism, 8453=Base)
CHAIN_ID=

# WebSocket endpoint for EVM event subscription (ws:// or wss://)
EVM_WS_RPC_URL=

# HTTP endpoint for EVM finality polling (http:// or https://)
EVM_HTTP_RPC_URL=

# Solana RPC endpoint
SOLANA_RPC_URL=https://api.devnet.solana.com

# Deployed InterlinkGateway contract address (0x...)
GATEWAY_ADDRESS=

# Deployed Solana Hub program ID (base58)
HUB_PROGRAM_ID=

# Path to the relayer's Solana keypair JSON file
KEYPAIR_PATH=~/.config/solana/id.json
